# --- META MARKETING API (Keystone's own ad account — no app review needed) ---
META_ACCESS_TOKEN=your_system_user_token_here
META_AD_ACCOUNT_ID=act_your_ad_account_id
META_PAGE_ID=your_facebook_page_id
GRAPH_API_VERSION=v25.0
DEFAULT_AD_SET_ID=
LANDING_PAGE_URL=https://keystonecleanerspa.com

# --- APIFY (competitor winning-ad intelligence) ---
APIFY_TOKEN=your_apify_token_here
APIFY_ACTOR_SLUG=harvestlab/facebook-ads-library-scraper

# --- ANTHROPIC (creative generation informed by competitor winners) ---
# Without this, creative generation falls back to fixed templates.
ANTHROPIC_API_KEY=

# --- CLASSIFICATION THRESHOLDS (tune once you have real data) ---
MIN_IMPRESSIONS=1000
CTR_GOOD=1.0
COST_PER_LEAD_MAX=40

PORT=3000
